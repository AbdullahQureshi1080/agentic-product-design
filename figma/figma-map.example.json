  "pages": {
    "_comment": "Map of Figma pages in this file. Keep this updated as you add pages.",
    "Flows": "All user flow screens — primary working page",
    "Components": "Component library — do not scan in LLM sessions",
    "Tokens": "Token definitions — do not scan in LLM sessions",
    "Archive": "Deprecated designs — do not scan in LLM sessions"
  },

  "mcp_targeting_rules": {
    "_comment": "Rules for how LLM sessions should reference this file when using Figma MCP.",
    "always_target_by_node_id": true,
    "never_scan_full_canvas": true,
    "never_access_pages": ["Components", "Tokens", "Archive"],
    "prefer_frame_name_over_search": true,
    "max_frames_per_mcp_call": 3,
    "update_node_id_after_creation": true
  },

  "status_definitions": {
    "todo": "Not started — no Figma frame exists yet",
    "wip": "Frame exists in Figma but design is in progress",
    "review": "Design complete, awaiting review",
    "done": "Reviewed and approved",
    "blocked": "Cannot proceed — blocked on decision or dependency"
  },

  "fidelity_definitions": {
    "wireframe": "Grayscale, structure only, no tokens applied",
    "hi-fi": "Full token-compliant, production-ready design"
  }
